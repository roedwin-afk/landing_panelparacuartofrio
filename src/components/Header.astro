---
import { Image } from "astro:assets";
import logo from "../assets/logo.svg";
import Menu from "./Menu.astro";
---

<header class="header">
    <div class="header__container">
        <div class="header__logo">
            <!-- <span class="header__logo-text">Panel Para Cuarto Frío</span> -->
            <a href="/">
                <Image
                    src={logo}
                    alt="Logo"
                    class="header__logo-img"
                    width={200}
                    height={50}
                    loading="eager"
                />
            </a>
        </div>
        <button class="header__toggle" id="menu-toggle"> ☰ </button>
        <nav class="header__nav" id="menu">
            <Menu />
        </nav>
    </div>
</header>

<style>
    .header {
        background-color: var(--color-primary);
        padding: 1rem 2rem;
        position: sticky;
        top: 0;
        z-index: 100;
        border-bottom: 2px solid rgba(255, 255, 255, 0.15);
    }

    .header__container {
        max-width: 1200px;
        margin: 0 auto;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .header__logo-text {
        color: var(--color-white);
        font-size: 1.25rem;
        font-weight: 700;
    }

    .header__nav {
        display: flex;
        gap: 2rem;
    }

    .header__logo {
        /* Quitamos el width fijo de 600px para que no empuje otros elementos */
        height: 3.5rem;
        display: flex;
        align-items: center;
    }

    .header__logo-img {
        /* Forzamos a que el logo crezca ignorando el espacio en blanco interno */
        height: 50px;
        width: 3rem;
        /* Un pequeño truco de escala si sigue viéndose pequeño */
        transform: scale(4.5);
        transform-origin: center;
    }

    .header__logo a {
        display: inline-block;
        cursor: pointer;
    }

    .header__toggle {
        display: none;
        font-size: 1.8rem;
        background: none;
        border: none;
        color: var(--color-white);
        cursor: pointer;
    }

    @media (max-width: 768px) {
        .header__container {
            flex-direction: row;
        }

        .header__toggle {
            display: block;
        }

        .header__nav {
            position: absolute;
            top: 100%;
            left: 0;
            width: 100%;
            background-color: var(--color-primary);
            flex-direction: column;
            align-items: center;
            gap: 1rem;
            padding: 1rem 0;

            display: none;
        }

        .header__nav.active {
            display: flex;
        }
    }
</style>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const toggle = document.getElementById("menu-toggle");
        const menu = document.getElementById("menu");

        if (toggle && menu) {
            toggle.addEventListener("click", () => {
                menu.classList.toggle("active");
            });
            // Cerrar menú al hacer clic en un link
            menu.querySelectorAll("a").forEach((link) => {
                link.addEventListener("click", () => {
                    menu.classList.remove("active");
                });
            });
        }
    });
</script>
