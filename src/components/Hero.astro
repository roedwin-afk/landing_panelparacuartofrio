---
import { Image } from "astro:assets";
import panelDePoliuretano from '../assets/paneles-de-poliuretano-en-el-salvador.webp';
---

<section class="hero fade-inn">
  <div class="hero__container">
    <div class="hero__content">
      <h1 class="hero__title">
        Panel para Cuarto Frío — Aislamiento Industrial de Alta Performance
      </h1>
      <p class="hero__description">
        Venta de paneles de poliuretano para cámaras frías. Cumplimiento con
        normativas TIF y FDA. Cobertura en El Salvador y Centroamérica.
      </p>
      <a href="/contacto" class="hero__btn">Solicitar cotización →</a>
    </div>
    <div class="hero__image">
      <Image
        src={panelDePoliuretano}
        alt="Paneles de poliuretano para cuarto frío"
        class="hero__image_class"
        width={600}
        height={400}
        loading="eager"
        priority
      />
    </div>
  </div>
</section>

<style>
  .hero {
    background-color: var(--color-primary);
    padding: 5rem 2rem;
    min-height: 500px;
  }

  .hero__container {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  .hero__title {
    color: var(--color-white);
    font-size: 2rem;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 1.5rem;
  }

  .hero__description {
    color: rgba(255, 255, 255, 0.85);
    font-size: 1.1rem;
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .hero__btn {
    display: inline-block;
    background-color: var(--color-accent);
    color: var(--color-white);
    padding: 0.85rem 2rem;
    border-radius: 4px;
    font-weight: 700;
    font-size: 1rem;
    transition: opacity 0.2s;
  }

  .hero__btn:hover {
    opacity: 0.9;
  }

  .hero__image .hero__image_class {
    border-radius: 8px;
    width: 100%;
    height: 400px;
    object-fit: cover;
  }

  .fade-in {
    opacity: 0;
    transform: translateY(40px);
    transition: all 0.6s ease;
  }

  .fade-in.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>
