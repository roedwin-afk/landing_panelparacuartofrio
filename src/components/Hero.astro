---
import panelDePoliuretano from "../assets/paneles-de-poliuretano-en-el-salvador.webp";
---

<section class="hero fade-in">
  <div class="hero__bg"></div>

  <div class="hero__content">
    <div class="hero__card">
      <h1 class="hero__title">
        Panel para Cuarto Frío — Aislamiento Industrial de Alta Performance
      </h1>

      <p class="hero__description">
        Paneles de poliuretano para cámaras frías con alta resistencia térmica,
        humedad y bajas temperaturas. Cumplimiento con normativas TIF, FDA y
        clasificación contra fuego EN-13501-1.
      </p>

      <a href="/contacto" class="hero__btn">
        Cotiza tu proyecto ahora →
      </a>

      <p class="hero__trust">
        +350 proyectos instalados en Centroamérica
      </p>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    background-image: url("/src/assets/paneles-de-poliuretano-en-el-salvador.png");
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    background: rgba(10, 20, 40, 0.40);
  }

  .hero__content {
    position: relative;
    z-index: 1;
    max-width: 700px;
    width: 100%;
    text-align: center;
  }

  .hero__card {
    background: rgba(44, 84, 122, 0.88);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 12px;
    padding: 3rem 3.5rem;
    backdrop-filter: blur(4px);
  }

  .hero__title {
    color: #ffffff;
    font-size: 2.4rem;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 1.2rem;
  }

  .hero__description {
    color: rgba(255, 255, 255, 0.88);
    font-size: 1.1rem;
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .hero__btn {
    display: inline-block;
    background-color: var(--color-accent);
    color: #ffffff;
    padding: 1rem 2.5rem;
    border-radius: 6px;
    font-weight: 700;
    font-size: 1.1rem;
    transition: all 0.2s;
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.3);
  }

  .hero__btn:hover {
    transform: translateY(-2px);
    opacity: 0.95;
  }

  .hero__trust {
    margin-top: 1.2rem;
    color: rgba(255, 255, 255, 0.6);
    font-size: 0.9rem;
  }

  .fade-in {
    opacity: 0;
    transform: translateY(40px);
    transition: all 0.6s ease;
  }

  .fade-in.visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 768px) {
    .hero {
      min-height: 80vh;
      padding: 2rem 1.2rem;
      background-position: 20% center;
    }

    .hero__card {
      padding: 2rem 1.5rem;
    }

    .hero__title {
      font-size: 1.8rem;
    }

    .hero__description {
      font-size: 1rem;
    }
  }
</style>
