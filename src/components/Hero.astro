---
import panelDePoliuretano from "../assets/paneles-de-poliuretano-en-el-salvador.webp";
---

<section class="hero fade-in">
  <div class="hero__overlay"></div>

  <div class="hero__content">
    <h1 class="hero__title">
      Panel para Cuarto Frío — Aislamiento Industrial de Alta Performance
    </h1>

    <p class="hero__description">
      Venta de paneles de poliuretano para cámaras frías. Cumplimiento con
      normativas TIF y FDA. Cobertura en El Salvador y Centroamérica.
    </p>

    <a href="/contacto" class="hero__btn">
      Cotiza tu proyecto ahora →
    </a>

    <p class="hero__trust">
      +350 proyectos instalados en Centroamérica
    </p>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 75vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    text-align: center;

    background-image: url("/src/assets/paneles-de-poliuretano-en-el-salvador.webp");
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  .hero__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    135deg,
    rgba(26, 58, 92, 0.75) 0%,
    rgba(26, 58, 92, 0.65) 50%,
    rgba(26, 58, 92, 0.4) 100%
  );
}

  .hero__content {
    position: relative;
    z-index: 1;
    max-width: 800px;
  }

  .hero__title {
    color: var(--color-white);
    font-size: 2.8rem;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 1.5rem;
  }

  .hero__description {
    color: rgba(255, 255, 255, 0.9);
    font-size: 1.2rem;
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .hero__btn {
    display: inline-block;
    background-color: var(--color-accent);
    color: var(--color-white);
    padding: 1rem 2.5rem;
    border-radius: 6px;
    font-weight: 700;
    font-size: 1.1rem;
    transition: all 0.2s;
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.25);
  }

  .hero__btn:hover {
    transform: translateY(-2px);
    opacity: 0.95;
  }

  .hero__trust {
    margin-top: 1.2rem;
    color: rgba(255, 255, 255, 0.75);
    font-size: 0.95rem;
  }

  .fade-in {
    opacity: 0;
    transform: translateY(40px);
    transition: all 0.6s ease;
  }

  .fade-in.visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 768px) {
    .hero {
      min-height: 70vh;
      padding: 2rem 1.5rem;
      background-position: 10% center;
    }

    .hero__title {
      font-size: 2rem;
    }

    .hero__description {
      font-size: 1rem;
    }
  }
</style>