---
import { Mail, Phone, MapPin } from "@lucide/astro";
import "leaflet/dist/leaflet.css";
---

<section class="contact fade-in">
  <div class="contact__container">
    <div class="contact__info">
      <h2>Solicita tu cotización</h2>
      <p>
        Contáctanos para asesorarte en la selección de paneles para tu cámara
        fría. Te respondemos lo más rápido posible.
      </p>

      <div class="contact__data">
        <p>
          <Mail size={18} />
          <a href="mailto:info@panelparacuartofrio.com">
            info@panelparacuartofrio.com
          </a>
        </p>
        <p>
          <Phone size={18} />
          <a href="tel:+525599903546">+52 55 9990 3546</a>
        </p>
        <p>
          <MapPin size={18} />
          <a
            href="https://maps.google.com/?cid=15759084979067732314&g_mp=Cidnb29nbGUubWFwcy5wbGFjZXMudjEuUGxhY2VzLlNlYXJjaFRleHQ"
            aria-label="Google Maps"
            target="_blank"
            rel="noopener noreferrer"
          >
            Avenida Presidente Masaryk No. 61, Int. 901 Colonia Polanco V
            Sección, C.P. 11560 Alcaldía Miguel Hidalgo, Ciudad de México,
            México
          </a>
        </p>
      </div>

      <div class="contact__social">
        <a
          href="https://facebook.com"
          target="_blank"
          rel="noopener"
          aria-label="Facebook"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="currentColor"
            ><path
              d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"
            ></path></svg
          >
        </a>
        <a
          href="https://instagram.com"
          target="_blank"
          rel="noopener"
          aria-label="Instagram"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path
              d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line
              x1="17.5"
              y1="6.5"
              x2="17.51"
              y2="6.5"></line></svg
          >
        </a>
        <a
          href="https://wa.me/525599903546"
          target="_blank"
          rel="noopener"
          aria-label="WhatsApp"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="currentColor"
            ><path
              d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"
            ></path></svg
          >
        </a>
        <a
          href="https://tiktok.com"
          target="_blank"
          rel="noopener"
          aria-label="TikTok"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="currentColor"
            ><path
              d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.75a4.85 4.85 0 0 1-1.01-.06z"
            ></path></svg
          >
        </a>
      </div>

      <div class="contact__map">
        <div
          id="contact-leaflet-map"
          class="contact__map-canvas"
          aria-label="Ubicación en mapa"
        >
        </div>
      </div>
    </div>

    <!-- ZOHO FORM -->
    <form
      class="contact__form"
      action="https://forms.zohopublic.com/promaica/form/SolicituddeCotizacin/formperma/0G7mUvm1mHqTMr77oTQpng90acA6JYYKZtboiNDls70/htmlRecords/submit"
      name="form"
      id="zoho-form"
      method="POST"
      accept-charset="UTF-8"
      enctype="multipart/form-data"
    >
      <input type="hidden" name="zf_referrer_name" value="" />
      <input type="hidden" name="zf_redirect_url" value="/gracias" />
      <input type="hidden" name="zc_gad" value="" />

      <div class="form__row">
        <div class="form__group">
          <label for="Name_First">Nombre</label>
          <input
            type="text"
            maxlength="255"
            name="Name_First"
            id="Name_First"
            placeholder="Nombre"
            required
          />
        </div>
        <div class="form__group">
          <label for="Name_Last">Apellido</label>
          <input
            type="text"
            maxlength="255"
            name="Name_Last"
            id="Name_Last"
            placeholder="Apellido"
            required
          />
        </div>
      </div>

      <div class="form__group">
        <label for="Email">Correo electrónico</label>
        <input
          type="email"
          name="Email"
          id="Email"
          maxlength="255"
          placeholder="correo@ejemplo.com"
          required
        />
      </div>

      <div class="form__group">
        <label for="PhoneNumber">Teléfono</label>
        <input
          type="tel"
          name="PhoneNumber_countrycode"
          id="PhoneNumber"
          maxlength="20"
          placeholder="+52 00 0000 0000"
        />
      </div>

      <div class="form__group">
        <label for="MultiLine">Mensaje</label>
        <textarea
          name="MultiLine"
          id="MultiLine"
          rows="5"
          placeholder="Cuéntanos qué necesitas..."
          required></textarea>
      </div>

      <button type="submit">Enviar solicitud →</button>
    </form>
  </div>
</section>

<link
  rel="stylesheet"
  href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
/>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" defer></script>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const customIcon = window.L.icon({
      iconUrl:
        "https://raw.githubusercontent.com/pointhi/leaflet-color-markers/master/img/marker-icon-orange.png",
      shadowUrl:
        "https://unpkg.com/leaflet@1.9.4/dist/images/marker-shadow.png",
      iconSize: [25, 41],
      iconAnchor: [12, 41],
      popupAnchor: [1, -34],
      shadowSize: [41, 41],
    });
    const mapContainer = document.getElementById("contact-leaflet-map");
    if (!mapContainer || typeof window === "undefined" || !window.L) return;

    const lat = 19.4326;
    const lng = -99.1946;

    const map = window.L.map("contact-leaflet-map").setView([lat, lng], 16);

    window.L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
      attribution: "&copy; OpenStreetMap contributors",
    }).addTo(map);

    window.L.marker([lat, lng], { icon: customIcon })
      .addTo(map)
      .bindPopup(
        `
        Masaryk 61, Int. 901, Polanco V, 11560, CDMX
      `,
      )
      .openPopup();

    setTimeout(() => {
      map.invalidateSize();
    }, 200);
  });
</script>

<style>
  .contact {
    padding: 4rem 2rem;
  }

  .contact__container {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 0.8fr 1.2fr;
    gap: 3rem;
    align-items: start;
  }

  .contact__info h2 {
    font-size: 2rem;
    margin-bottom: 1rem;
    color: var(--color-primary);
  }

  .contact__info p {
    margin-bottom: 1rem;
    line-height: 1.6;
    color: var(--color-text);
  }

  .contact__data p {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 600;
  }

  .contact__data a {
    color: var(--color-primary);
    text-decoration: none;
  }

  .contact__data a:hover {
    color: var(--color-accent);
    text-decoration: underline;
  }

  .contact__data svg {
    color: var(--color-primary);
    flex-shrink: 0;
    width: 18px;
    height: 18px;
  }

  .contact__social {
    display: flex;
    gap: 1rem;
    margin: 1rem 0;
  }

  .contact__social a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    border-radius: 999px;
    background: rgba(44, 84, 122, 0.08);
    transition:
      background-color 0.2s ease,
      transform 0.2s ease;
  }

  .contact__social a svg {
    color: var(--color-primary);
    transition: color 0.2s ease;
  }

  .contact__social a:hover {
    background: var(--color-accent);
    transform: translateY(-2px);
  }

  .contact__social a:hover svg {
    color: var(--color-white);
  }

  .contact__map {
    margin-top: 1rem;
  }
  #contact-map {
    width: 100%;
    height: 220px;
    border-radius: 8px;
    overflow: hidden;
  }

  .contact__map-canvas {
    width: 100%;
    height: 260px;
    border-radius: 14px;
    overflow: hidden;
    border: 1px solid rgba(44, 84, 122, 0.12);
    box-shadow: 0 10px 30px rgba(44, 84, 122, 0.12);
    background: #f5f7fa;
  }

  /* Popup */
  :global(.leaflet-popup-content-wrapper) {
    border-radius: 12px;
  }

  :global(.leaflet-popup-content) {
    font-family: var(--font-base);
    color: var(--color-text);
    line-height: 1.5;
  }

  :global(.leaflet-control-zoom a) {
    color: var(--color-primary);
  }

  :global(.leaflet-control-attribution) {
    font-family: var(--font-base);
    font-size: 11px;
  }

  /* Marker personalizado */
  :global(.contact__marker-wrapper) {
    background: transparent;
    border: 0;
  }

  :global(.contact__marker-pin) {
    width: 28px;
    height: 28px;
    background: var(--color-primary);
    border: 3px solid var(--color-white);
    border-radius: 50% 50% 50% 0;
    transform: rotate(-45deg);
    box-shadow: 0 8px 18px rgba(44, 84, 122, 0.28);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  :global(.contact__marker-dot) {
    width: 10px;
    height: 10px;
    background: var(--color-accent);
    border-radius: 50%;
    transform: rotate(45deg);
    display: block;
  }

  /* FORM */
  .contact__form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .form__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .form__group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .form__group label {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-primary);
  }

  .contact__form input,
  .contact__form textarea {
    padding: 0.9rem;
    border: 1px solid #ddd;
    border-radius: 8px;
    font-family: inherit;
    font-size: 1rem;
    transition:
      border 0.2s,
      box-shadow 0.2s;
    color: var(--color-text);
    background: var(--color-white);
  }

  .contact__form input:focus,
  .contact__form textarea:focus {
    outline: none;
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(232, 160, 32, 0.18);
  }

  .contact__form button {
    background-color: var(--color-accent);
    color: var(--color-white);
    padding: 1rem;
    border: none;
    font-weight: 700;
    font-size: 1rem;
    cursor: pointer;
    border-radius: 8px;
    transition:
      transform 0.2s,
      opacity 0.2s,
      box-shadow 0.2s;
    box-shadow: 0 10px 20px rgba(232, 160, 32, 0.22);
  }

  .contact__form button:hover {
    transform: translateY(-2px);
    opacity: 0.96;
  }

  @media (max-width: 768px) {
    .contact {
      padding: 3rem 1.5rem;
    }

    .contact__container {
      grid-template-columns: 1fr;
    }

    .contact__info h2 {
      font-size: 1.5rem;
    }

    .form__row {
      grid-template-columns: 1fr;
    }

    .contact__map-canvas {
      height: 240px;
    }
  }
</style>
