---
import { Image } from "astro:assets";
import industriaAlimentaria from "../assets/Industria alimentaria.png";
import sectorFarmaceutico from "../assets/Sector farmacéutico.webp";
import logisticaYDistribucion from "../assets/Logística y distribución.jpg";
import agroindustria from "../assets/Agroindustria.jpg";

const aplicaciones = [
  {
    imagen: industriaAlimentaria,
    titulo: "Industria alimentaria",
    texto:
      "Cámaras de conservación, congelación y proceso para plantas de alimentos.",
  },
  {
    imagen: sectorFarmaceutico,
    titulo: "Sector farmacéutico",
    texto:
      "Almacenamiento de medicamentos y vacunas bajo temperatura controlada.",
  },
  {
    imagen: logisticaYDistribucion,
    titulo: "Logística y distribución",
    texto:
      "Cuartos fríos para centros de distribución y transporte refrigerado.",
  },
  {
    imagen: agroindustria,
    titulo: "Agroindustria",
    texto:
      "Conservación de frutas, verduras y productos perecederos post-cosecha.",
  },
];
---

<section class="aplicaciones fade-in" id="aplicaciones">
  <div class="aplicaciones__container">
    <h2 class="aplicaciones__titulo">Aplicaciones</h2>
    <div class="aplicaciones__grid">
      {
        aplicaciones.map((a) => (
          <div class="aplicaciones__card">
            <Image
              src={a.imagen}
              alt={a.titulo}
              class="aplicaciones__img"
              width={200}
              height={180}
              format="webp"
              quality={80}
            />
            <div class="aplicaciones__info">
              <h3 class="aplicaciones__nombre">{a.titulo}</h3>
              <p class="aplicaciones__texto">{a.texto}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .aplicaciones {
    padding: 5rem 2rem;
    background-color: #f8f9fa;
  }

  .aplicaciones__container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .aplicaciones__titulo {
    text-align: center;
    color: var(--color-primary);
    font-size: 1.75rem;
    font-weight: 700;
    margin-bottom: 3rem;
  }

  .aplicaciones__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  .aplicaciones__card {
    background: var(--color-white);
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
  }

  .aplicaciones__img {
    width: 100%;
    height: 180px;
    object-fit: cover;
  }

  .aplicaciones__info {
    padding: 1.25rem;
  }

  .aplicaciones__nombre {
    color: var(--color-primary);
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .aplicaciones__texto {
    color: #555;
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .fade-in {
    opacity: 0;
    transform: translateY(40px);
    transition: all 0.6s ease;
  }

  .fade-in.visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 768px) {
    .aplicaciones__grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 480px) {
    .aplicaciones__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
