---
import { Image } from "astro:assets";
import industriaAlimentaria from "../assets/Industria alimentaria.png";
import sectorFarmaceutico from "../assets/Sector farmacéutico.webp";
import logisticaYDistribucion from "../assets/Logística y distribución.jpg";
import agroindustria from "../assets/Agroindustria.jpg";

const aplicaciones = [
  {
    imagen: industriaAlimentaria,
    titulo: "Industria alimentaria",
    texto:
      "Cámaras de conservación, congelación y proceso para plantas de alimentos con control térmico preciso y cumplimiento sanitario.",
  },
  {
    imagen: sectorFarmaceutico,
    titulo: "Sector farmacéutico",
    texto:
      "Almacenamiento de medicamentos y vacunas bajo temperatura controlada, garantizando estabilidad y cumplimiento normativo.",
  },
  {
    imagen: logisticaYDistribucion,
    titulo: "Logística y distribución",
    texto:
      "Cuartos fríos para centros de distribución y transporte refrigerado, optimizando la cadena de frío y reduciendo pérdidas.",
  },
  {
    imagen: agroindustria,
    titulo: "Agroindustria",
    texto:
      "Conservación de frutas, verduras y productos perecederos postcosecha, prolongando la vida útil y manteniendo la calidad.",
  },
];
---

<section class="aplicaciones fade-in" id="aplicaciones">
  <div class="aplicaciones__container">
    <div class="aplicaciones__header">
      <h2 class="aplicaciones__titulo">Soluciones para diferentes industrias</h2>

      <div class="aplicaciones__controls">
        <button
          class="aplicaciones__button aplicaciones__button--prev"
          type="button"
          aria-label="Aplicación anterior"
        >
          ‹
        </button>

        <button
          class="aplicaciones__button aplicaciones__button--next"
          type="button"
          aria-label="Siguiente aplicación"
        >
          ›
        </button>
      </div>
    </div>

    <div class="aplicaciones__slider">
      {
        aplicaciones.map((a, index) => (
          <article
            class={`aplicaciones__card ${index === 0 ? "is-active" : ""}`}
            data-index={index}
          >
            <div class="aplicaciones__image-wrap">
              <Image
                src={a.imagen}
                alt={a.titulo}
                class="aplicaciones__img"
                width={420}
                height={280}
                format="webp"
                quality={80}
              />
            </div>

            <div class="aplicaciones__info">
              <h3 class="aplicaciones__nombre">{a.titulo}</h3>
              <p class="aplicaciones__texto">{a.texto}</p>
            </div>
          </article>
        ))
      }
    </div>

    <div class="aplicaciones__dots" aria-label="Navegación del carrusel">
      {
        aplicaciones.map((_, index: number) => (
          <button
            class={`aplicaciones__dot ${index === 0 ? "is-active" : ""}`}
            type="button"
            aria-label={`Ir a la aplicación ${index + 1}`}
            data-index={index}
          />
        ))
      }
    </div>
  </div>
</section>

<script src="../scripts/aplicaciones-carousel.ts"></script>

<style>
  .aplicaciones {
    padding: 5rem var(--container-padding);
    background-color: #f8f9fa;
    overflow: hidden;
  }

  .aplicaciones__container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .aplicaciones__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 2.5rem;
  }

  .aplicaciones__titulo {
    color: var(--color-primary);
    font-size: 1.75rem;
    font-weight: 700;
    margin: 0;
  }

  .aplicaciones__controls {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .aplicaciones__button {
    width: 44px;
    height: 44px;
    border: 1px solid rgba(44, 84, 122, 0.15);
    border-radius: 999px;
    background: var(--color-white);
    color: var(--color-primary);
    font-size: 1.75rem;
    line-height: 1;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .aplicaciones__button:hover {
    background: var(--color-primary);
    color: var(--color-white);
  }

  .aplicaciones__slider {
    position: relative;
    height: 500px;
    display: flex;
    align-items: center;
    justify-content: center;
    perspective: 1200px;
  }

  .aplicaciones__card {
    position: absolute;
    width: min(100%, 500px);
    background: var(--color-white);
    border-radius: 18px;
    overflow: hidden;
    box-shadow: 0 12px 35px rgba(0, 0, 0, 0.12);
    transition:
      transform 0.7s ease,
      opacity 0.7s ease,
      filter 0.7s ease,
      box-shadow 0.7s ease;
    will-change: transform, opacity;
    opacity: 0;
    pointer-events: none;
  }

  .aplicaciones__card.is-active,
  .aplicaciones__card.is-left,
  .aplicaciones__card.is-right {
    opacity: 1;
    pointer-events: auto;
  }

  .aplicaciones__card.is-active {
    transform: translateX(0) scale(1);
    z-index: 3;
    filter: blur(0);
    box-shadow: 0 18px 45px rgba(0, 0, 0, 0.18);
  }

  .aplicaciones__card.is-left {
    transform: translateX(-62%) scale(0.86);
    z-index: 2;
    opacity: 0.76;
    filter: grayscale(10%) brightness(0.92);
  }

  .aplicaciones__card.is-right {
    transform: translateX(62%) scale(0.86);
    z-index: 2;
    opacity: 0.76;
    filter: grayscale(10%) brightness(0.92);
  }

  .aplicaciones__card.is-hidden-left {
    transform: translateX(-135%) scale(0.68);
    z-index: 1;
    opacity: 0;
    filter: blur(2px);
  }

  .aplicaciones__card.is-hidden-right {
    transform: translateX(135%) scale(0.68);
    z-index: 1;
    opacity: 0;
    filter: blur(2px);
  }

  .aplicaciones__image-wrap {
    position: relative;
  }

  .aplicaciones__img {
    width: 100%;
    height: 240px;
    object-fit: cover;
    display: block;
  }

  .aplicaciones__info {
    padding: 1.35rem;
    text-align: center;
  }

  .aplicaciones__nombre {
    color: var(--color-primary);
    font-size: 1.1rem;
    font-weight: 700;
    margin: 0 0 0.65rem;
  }

  .aplicaciones__texto {
    color: #555;
    font-size: 0.95rem;
    line-height: 1.6;
    margin: 0;
  }

  .aplicaciones__dots {
    display: flex;
    justify-content: center;
    gap: 0.65rem;
    margin-top: 2rem;
  }

  .aplicaciones__dot {
    width: 10px;
    height: 10px;
    border: none;
    border-radius: 999px;
    background: rgba(44, 84, 122, 0.25);
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .aplicaciones__dot.is-active {
    background: var(--color-accent);
    transform: scale(1.15);
  }

  .fade-in {
    opacity: 0;
    transform: translateY(40px);
    transition: all 0.6s ease;
  }

  .fade-in.visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 991px) {
    .aplicaciones__slider {
      height: 470px;
    }

    .aplicaciones__card {
      width: min(100%, 340px);
    }

    .aplicaciones__card.is-left {
      transform: translateX(-58%) scale(0.8);
    }

    .aplicaciones__card.is-right {
      transform: translateX(58%) scale(0.8);
    }
  }

  @media (max-width: 768px) {
    .aplicaciones {
      padding: 3rem var(--container-padding-mobile);
    }

    .aplicaciones__header {
      flex-direction: column;
      align-items: flex-start;
      margin-bottom: 1.5rem;
    }

    .aplicaciones__controls {
      align-self: flex-end;
    }

    .aplicaciones__slider {
      height: 430px;
    }

    .aplicaciones__card {
      width: min(100%, 300px);
    }

    .aplicaciones__card.is-left {
      transform: translateX(-32%) scale(0.72);
      opacity: 0.38;
    }

    .aplicaciones__card.is-right {
      transform: translateX(32%) scale(0.72);
      opacity: 0.38;
    }

    .aplicaciones__img {
      height: 200px;
    }

    .aplicaciones__texto {
      font-size: 0.92rem;
    }
  }

  @media (max-width: 480px) {
    .aplicaciones__slider {
      height: 410px;
    }

    .aplicaciones__card {
      width: min(100%, 280px);
    }

    .aplicaciones__card.is-left {
      transform: translateX(-24%) scale(0.68);
      opacity: 0.25;
    }

    .aplicaciones__card.is-right {
      transform: translateX(24%) scale(0.68);
      opacity: 0.25;
    }
  }
</style>
