---
import { Image } from "astro:assets";
import logo from "../assets/logo.png";
---

<footer class="footer">
  <div class="footer__container">
    <div class="footer__marca">
      <Image
        src={logo}
        alt="Logo"
        class="footer__logo-img"
        width={200}
        height={50}
        loading="eager"
      />
      <br />
      <p class="footer__desc">
        Venta de paneles de poliuretano para cámaras frías en El Salvador y
        Centroamérica.
      </p>
    </div>
    <div class="footer__links">
      <h4>Navegación</h4>
      <a href="#soluciones">Soluciones</a>
      <a href="#aplicaciones">Aplicaciones</a>
      <a href="#contacto">Contacto</a>
    </div>
    <div class="footer__contacto">
      <h4>Contacto</h4>
      <p>info@panelparacuartofrio.com</p>
      <p>+503 6543 2109</p>
      <p>San Miguel, El Salvador y Centroamérica</p>
    </div>
  </div>
  <div class="footer__copy">
    <p>© 2026 PanelParaCuartoFrío. Todos los derechos reservados.</p>
  </div>
</footer>

<style>
  .footer {
    background-color: #0f2337;
    color: rgba(255, 255, 255, 0.75);
    padding: 4rem 2rem 2rem;
  }

  .footer__container {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 3rem;
    margin-bottom: 3rem;
  }

  .footer__logo {
    display: block;
    color: var(--color-white);
    font-size: 1.2rem;
    font-weight: 700;
    margin-bottom: 1rem;
  }

  .footer__desc {
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .footer__links h4,
  .footer__contacto h4 {
    color: var(--color-white);
    font-size: 0.95rem;
    font-weight: 700;
    margin-bottom: 1rem;
  }

  .footer__links a {
    display: block;
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
    transition: color 0.2s;
  }

  .footer__links a:hover {
    color: var(--color-accent);
  }

  .footer__contacto p {
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
  }

  .footer__copy {
    max-width: 1200px;
    margin: 0 auto;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    text-align: center;
    font-size: 0.85rem;
  }

  @media (max-width: 768px) {
    .footer__container {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
</style>
