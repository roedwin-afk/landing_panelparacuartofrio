  </div>
  <div class="footer__copy">
    <p>© <span id="year"></span> Panel Para Cuarto Frío</p>
  </div>
</footer>

<style>
  .footer {
    background-color: #0f2337;
    color: rgba(255, 255, 255, 0.75);
    padding: 4rem 2rem 2rem;
  }

  .footer__container {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 3rem;
    margin-bottom: 3rem;
  }

  .footer__logo {
    display: block;
    color: var(--color-white);
    font-size: 1.2rem;
    font-weight: 700;
    margin-bottom: 1rem;
  }
  .footer__logo-img {
    /* Forzamos a que el logo crezca ignorando el espacio en blanco interno */
    height: 50px;
    width: 3rem;
    /* Un pequeño truco de escala si sigue viéndose pequeño */
    transform: scale(5.5);
    transform-origin: left center;
  }

  .footer__desc {
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .footer__links h4,
  .footer__contacto h4 {
    color: var(--color-white);
    font-size: 0.95rem;
    font-weight: 700;
    margin-bottom: 1rem;
  }

  .footer__contacto a {
    color: rgba(255, 255, 255, 0.75);
    text-decoration: none;
  }

  .footer__contacto a:hover {
    color: var(--color-accent);
  }

  .footer__links a {
    display: block;
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
    transition: color 0.2s;
  }

  .footer__links a:hover {
    color: var(--color-accent);
  }

  .footer__contacto p {
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
  }

  .footer__copy {
    max-width: 1200px;
    margin: 0 auto;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    text-align: center;
    font-size: 0.85rem;
  }

  .footer__social {
    display: flex;
    gap: 1rem;
    margin-top: 1.25rem;
  }

  .footer__social a {
    color: rgba(255, 255, 255, 0.6);
    transition: color 0.2s;
    display: flex;
    align-items: center;
  }

  .footer__social a:hover {
    color: var(--color-accent);
  }

  @media (max-width: 768px) {
    .footer__container {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .footer__marca {
      text-align: center;
    }

    .footer__logo-img {
      display: block;
      margin: 0 auto;
    }
  }
</style>
<script>
  const el = document.getElementById("year");
  if (el) el.textContent = String(new Date().getFullYear());
</script>
