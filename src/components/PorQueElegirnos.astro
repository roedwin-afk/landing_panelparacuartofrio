---
import { Clock, Building2, MessageCircle, Award } from "@lucide/astro";

const icons = {
  clock: Clock,
  building: Building2,
  message: MessageCircle,
  award: Award,
};
type IconName = "clock" | "building" | "message" | "award";
const stats: {
  icono: IconName;
  numero: string;
  texto: string;
}[] = [
  {
    icono: "clock",
    numero: "+10",
    texto: "Años de experiencia en soluciones de aislamiento industrial",
  },
  {
    icono: "building",
    numero: "+350",
    texto: "Proyectos instalados en la región centroamericana",
  },
  {
    icono: "message",
    numero: "Asesoría",
    texto: "Te ayudamos a elegir el panel correcto para tu proyecto",
  },
  {
    icono: "award",
    numero: "Certificaciones",
    texto: "Internacionales en materiales y procesos de fabricación",
  },
];
---

<section class="stats fade-in">
  <div class="stats__container">
    <h2 class="stats__titulo">¿Por qué elegirnos?</h2>
    <div class="stats__grid">
      {
        stats.map((s) => (
          <div class="stats__card">
            <span class="stats__icono">
              {(() => {
                const Icon = icons[s.icono];
                return Icon ? (
                  <Icon size={28} color="var(--color-primary)" />
                ) : null;
              })()}
            </span>
            <span class="stats__numero">{s.numero}</span>
            <p class="stats__texto">{s.texto}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .stats {
    padding: 5rem 2rem;
    background-color: var(--color-white);
  }

  .stats__container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .stats__titulo {
    text-align: center;
    color: var(--color-primary);
    font-size: 1.75rem;
    font-weight: 700;
    margin-bottom: 3rem;
  }

  .stats__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 2rem;
  }

  .stats__card {
    text-align: center;
    padding: 2rem 1rem;
    border-top: 3px solid var(--color-accent);
  }

  .stats__card:hover .stats__icono svg {
    stroke: var(--color-accent);
  }

  .stats__icono {
    font-size: 2rem;
    display: block;
    margin-bottom: 0.75rem;
  }
  .stats__icono svg {
    width: 28px;
    height: 28px;
    stroke: var(--color-primary);
  }

  .stats__numero {
    display: block;
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 0.5rem;
  }

  .stats__texto {
    color: #555;
    font-size: 0.9rem;
    line-height: 1.6;
  }
  .fade-in {
    opacity: 0;
    transform: translateY(40px);
    transition: all 0.6s ease;
  }

  .fade-in.visible {
    opacity: 1;
    transform: translateY(0);
  }
  @media (max-width: 768px) {
    .stats {
      padding: 3rem 1rem;
    }

    .stats__texto {
      font-size: 1rem;
    }

    .stats__card {
      padding: 1.5rem 1rem;
    }
  }
  @media (max-width: 480px) {
    .stats__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
