<section class="cta fade-in" id="contacto">
  <div class="cta__container">
    <h2 class="cta__titulo">¿Listo para optimizar tu cuarto frío?</h2>
    <p class="cta__texto">Cuéntanos tu proyecto y un especialista te contactará con una propuesta técnica personalizada.</p>
    <a href="/contacto" class="cta__btn">Solicitar cotización gratuita →</a>
  </div>
</section>

<style>
  .cta {
    background-color: var(--color-primary);
    padding: 5rem 2rem;
    text-align: center;
  }

  .cta__container {
    max-width: 700px;
    margin: 0 auto;
  }

  .cta__titulo {
    color: var(--color-white);
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 1rem;
  }

  .cta__texto {
    color: rgba(255,255,255,0.85);
    font-size: 1.1rem;
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .cta__btn {
    display: inline-block;
    background-color: var(--color-accent);
    color: var(--color-white);
    padding: 1rem 2.5rem;
    border-radius: 4px;
    font-weight: 700;
    font-size: 1rem;
    transition: opacity 0.2s;
  }

  .cta__btn:hover {
    opacity: 0.9;
  }
</style>