---
import { Thermometer, AlertTriangle, Wrench } from "@lucide/astro";

const icons = {
  temperatura: Thermometer,
  riesgo: AlertTriangle,
  instalacion: Wrench,
};

type IconName = "temperatura" | "riesgo" | "instalacion";

const problemas: {
  icono: IconName;
  titulo: string;
  texto: string;
}[] = [
  {
    icono: "temperatura",
    titulo: "Pérdidas de temperatura",
    texto:
      "Un aislamiento deficiente aumenta la conductividad térmica, elevando hasta un 40% el consumo energético y comprometiendo la cadena de frío.",
  },
  {
    icono: "riesgo",
    titulo: "Riesgos de cumplimiento",
    texto:
      "El uso de materiales no certificados puede impedir cumplir normativas sanitarias como TIF o FDA, generando sanciones o cierre de operaciones.",
  },
  {
    icono: "instalacion",
    titulo: "Instalaciones ineficientes",
    texto:
      "Los sistemas tradicionales son más lentos de instalar, menos resistentes a humedad y desgaste, y generan mayores costos a largo plazo.",
  },
];
---

<section class="problemas fade-in">
  <div class="problemas__container">
    <h2 class="problemas__titulo-seccion">
      Problemas que un mal aislamiento puede causar
    </h2>

    <div class="problemas__grid">
      {
        problemas.map((p) => (
          <div class="problemas__card">
            <span class="problemas__icono">
              {(() => {
                const Icon = icons[p.icono];
                return Icon ? <Icon size={28} /> : null;
              })()}
            </span>

            <h3 class="problemas__titulo">{p.titulo}</h3>
            <p class="problemas__texto">{p.texto}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .problemas {
    padding: 5rem 2rem;
    background-color: #f8f9fa;
  }

  .problemas__container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .problemas__titulo-seccion {
    text-align: center;
    color: var(--color-primary);
    font-size: 1.75rem;
    font-weight: 700;
    margin-bottom: 3rem;
    max-width: 680px;
    margin-left: auto;
    margin-right: auto;
  }

  .problemas__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 2rem;
  }

  .problemas__card {
    text-align: center;
    padding: 2rem 1rem;
    border-top: 3px solid var(--color-accent);
    background-color: var(--color-white);
  }

  .problemas__card:hover .problemas__icono svg {
    stroke: var(--color-accent);
  }

  .problemas__icono {
    display: block;
    margin-bottom: 0.75rem;
  }

  .problemas__icono svg {
    width: 28px;
    height: 28px;
    stroke: var(--color-primary);
  }

  .problemas__titulo {
    color: var(--color-primary);
    font-size: 1.15rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
  }

  .problemas__texto {
    color: #555;
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .fade-in {
    opacity: 0;
    transform: translateY(40px);
    transition: all 0.6s ease;
  }

  .fade-in.visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 768px) {
    .problemas {
      padding: 3rem 1rem;
    }

    .problemas__texto {
      font-size: 1rem;
    }

    .problemas__card {
      padding: 1.5rem 1rem;
    }
  }

  @media (max-width: 480px) {
    .problemas__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
