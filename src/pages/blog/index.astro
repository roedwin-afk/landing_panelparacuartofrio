---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

const posts = [
  {
    id: 1,
    date: "2026-04-10T12:00:00",
    slug: "instalacion-cuartos-frios",
    title: {
      rendered: "Instalación de Cuartos Fríos: Guía Completa"
    },
    excerpt: {
      rendered: "Aprende los aspectos clave para instalar un cuarto frío eficiente y duradero."
    },
    content: {
      rendered: "<p>Contenido completo del post sobre instalación de cuartos fríos...</p>"
    },
    _embedded: {
      "wp:featuredmedia": [
        {
          source_url: "https://via.placeholder.com/800x400?text=Cuarto+Frio"
        }
      ]
    }
  },
  {
    id: 2,
    date: "2026-04-08T10:30:00",
    slug: "paneles-aislantes-beneficios",
    title: {
      rendered: "Beneficios de los Paneles Aislantes"
    },
    excerpt: {
      rendered: "Descubre por qué los paneles aislantes son clave en la refrigeración."
    },
    content: {
      rendered: "<p>Contenido sobre los beneficios de los paneles aislantes...</p>"
    },
    _embedded: {
      "wp:featuredmedia": [
        {
          source_url: "https://via.placeholder.com/800x400?text=Paneles"
        }
      ]
    }
  },
  {
    id: 3,
    date: "2026-04-05T09:00:00",
    slug: "mantenimiento-cuartos-frios",
    title: {
      rendered: "Mantenimiento de Cuartos Fríos"
    },
    excerpt: {
      rendered: "Consejos prácticos para alargar la vida útil de tu cuarto frío."
    },
    content: {
      rendered: "<p>Guía de mantenimiento preventivo y correctivo...</p>"
    },
    _embedded: {
      "wp:featuredmedia": [
        {
          source_url: "https://via.placeholder.com/800x400?text=Mantenimiento"
        }
      ]
    }
  }
];

//const response = await fetch(`${import.meta.env.WORDPRESS_API_URL}/posts?_embed&per_page=100`);
//const posts = await response.json();

const base = import.meta.env.BASE_URL;
---

<Layout
    title="Blog | Panel Para Cuarto Frío"
    description="Información sobre paneles de poliuretano, aislamiento industrial y proyectos de refrigeración."
>
    <Header />

    <main class="blog">
        <div class="blog__container">
            <div class="blog__header">
                <h1 class="blog__title">Blog</h1>
                <p class="blog__description">
                    Información sobre paneles de poliuretano, aislamiento
                    industrial y proyectos de refrigeración en El Salvador y
                    Centroamérica.
                </p>
            </div>

            <div class="blog__grid">
                {
                    posts.map((post: any) => (
                        <article class="blog-card">
                            {post._embedded?.["wp:featuredmedia"]?.[0]
                                ?.source_url && (
                                <img
                                    src={
                                        post._embedded["wp:featuredmedia"][0]
                                            .source_url
                                    }
                                    alt={post.title.rendered}
                                    class="blog-card__image"
                                />
                            )}
                            <div class="blog-card__content">
                                <p class="blog-card__date">
                                    {new Date(post.date).toLocaleDateString(
                                        "es-SV",
                                        {
                                            year: "numeric",
                                            month: "long",
                                            day: "numeric",
                                        },
                                    )}
                                </p>
                                <h2 class="blog-card__title">
                                    <a
                                        href={`${base}blog/${post.slug}/`}
                                        set:html={post.title.rendered}
                                    />
                                </h2>
                                <p
                                    class="blog-card__description"
                                    set:html={post.excerpt.rendered}
                                />
                                <a
                                    href={`${base}blog/${post.slug}/`}
                                    class="blog-card__link"
                                >
                                    Leer más →
                                </a>
                            </div>
                        </article>
                    ))
                }
            </div>
        </div>
    </main>

    <Footer />
</Layout>
<style>
    .blog {
        padding: 4rem 2rem;
        background-color: #f8f9fa;
    }

    .blog__container {
        max-width: 1200px;
        margin: 0 auto;
    }

    .blog__header {
        text-align: center;
        margin-bottom: 3rem;
    }

    .blog__title {
        font-size: 2.5rem;
        color: var(--color-primary);
        margin-bottom: 1rem;
    }

    .blog__description {
        max-width: 700px;
        margin: 0 auto;
        color: #555;
        line-height: 1.7;
    }

    .blog__grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 2rem;
    }

    .blog-card {
        background: #fff;
        border-radius: 10px;
        overflow: hidden;
        box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
    }

    .blog-card__image {
        width: 100%;
        height: 220px;
        object-fit: cover;
    }

    .blog-card__content {
        padding: 1.5rem;
    }

    .blog-card__date {
        font-size: 0.85rem;
        color: #777;
        margin-bottom: 0.75rem;
    }

    .blog-card__title {
        font-size: 1.2rem;
        margin-bottom: 0.75rem;
    }

    .blog-card__title a {
        color: var(--color-primary);
    }

    .blog-card__description {
        color: #555;
        line-height: 1.6;
        margin-bottom: 1rem;
    }

    .blog-card__link {
        color: var(--color-accent);
        font-weight: 700;
    }

    @media (max-width: 900px) {
        .blog__grid {
            grid-template-columns: 1fr 1fr;
        }
    }

    @media (max-width: 640px) {
        .blog__grid {
            grid-template-columns: 1fr;
        }
    }
</style>
