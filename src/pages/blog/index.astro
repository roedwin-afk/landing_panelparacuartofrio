---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import ListadoBlogs from "../../components/ListadoBlogs.astro";
import { MOCK_POSTS } from "../../data/posts";

const POSTS_PER_PAGE = 6;
const allPosts = MOCK_POSTS;
const totalPages = Math.ceil(allPosts.length / POSTS_PER_PAGE);
const posts = allPosts.slice(0, POSTS_PER_PAGE);
---

<Layout
    title="Blog — Aislamiento Térmico Industrial | El Salvador"
    description="Venta de paneles sándwich para techos industriales. Alta resistencia y eficiencia térmica. Cobertura en El Salvador y Centroamérica."
>
    <Header />

    <ListadoBlogs
        posts={posts}
        paginaActual={1}
        totalPaginas={totalPages}
        rutaBase="/blog/page/"
    />

    <Footer />
</Layout>
